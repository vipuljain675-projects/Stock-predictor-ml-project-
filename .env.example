# Aegis Markets API Configuration
# Copy this file to .env and fill in the values

# FastAPI configuration
PORT=8000

# Groq API Key (Recommended for chat and shock detection — higher quota)
# Get a key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (Optional — used as fallback or for Gemini Search headlines)
# Get a key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
